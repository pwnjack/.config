# Appearance
font=FiraCode Nerd Font 11
background-color=#0E0E0Edd
text-color=#dccea8
border-color=#D9754B
border-size=2
border-radius=10
max-icon-size=64

# Behavior
max-visible=5
layer=overlay
default-timeout=5000
ignore-timeout=0

# Position
anchor=top-right
margin=20

# Grouping
group-by=app-name

# Urgency levels
[urgency=low]
border-color=#915A3B
default-timeout=3000

[urgency=normal]
border-color=#D9754B
default-timeout=5000

[urgency=critical]
border-color=#5B7352
background-color=#5B735222
default-timeout=0

# Application specific (examples)
[app-name="Spotify"]
