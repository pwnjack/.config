# Ghostty Configuration
# Docs: https://ghostty.org/docs/config
# Run `ghostty +show-config --default --docs` to list all options.
#
# Colors are rendered into ~/.cache/wal/ghostty-colors by
# ~/.config/ghostty/apply_wal_colors.sh on every wallpaper change, and
# included below via `config-file = ?colors` (ghostty/colors is a symlink
# to the rendered file).

font-family = "FiraCode Nerd Font"

# Conventional keybinds
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_clipboard

# pywal colors
config-file = ?colors
