# Ghostty Configuration
# Docs: https://ghostty.org/docs/config
# Run `ghostty +show-config --default --docs` to list all options.
#
# The pywal block at the bottom is regenerated by
# ~/.config/ghostty/apply_wal_colors.sh on every wallpaper change.

font-family = "Fira Code Nerd Font"

# Conventional keybinds
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_clipboard

# pywal colors start
# Automatically generated - do not edit manually

background = #05090C
foreground = #cfddde
cursor-color = #cfddde

palette = 0=#05090C
palette = 1=#2A7789
palette = 2=#4D7D85
palette = 3=#318A9B
palette = 4=#6097A1
palette = 5=#8DAFB4
palette = 6=#9ABBC2
palette = 7=#cfddde
palette = 8=#909a9b
palette = 9=#2A7789
palette = 10=#4D7D85
palette = 11=#318A9B
palette = 12=#6097A1
palette = 13=#8DAFB4
palette = 14=#9ABBC2
palette = 15=#cfddde

# pywal colors end
